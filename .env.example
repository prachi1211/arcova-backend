# Server
PORT=3001
NODE_ENV=development

# Supabase — get these from your Supabase project dashboard (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key
SUPABASE_PUBLISHABLE_KEY=eyJ...your-publishable-key

# Anthropic — optional, AI chat degrades gracefully without it
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — optional, payments degrade gracefully without it
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CORS — frontend URL(s), comma-separated for multiple origins
CORS_ORIGIN=http://localhost:5173
